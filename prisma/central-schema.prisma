// ════════════════════════════════════════════════════════════════
//  BIMON — Central Database (Neon)
//  Shared across all game deployments (BGMI, PES, Free Fire, etc.)
//  Wallet, Community, Polls, Cross-Game Transfers, Settlement
// ════════════════════════════════════════════════════════════════

generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/central-client"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionReason {
  TOURNAMENT_WIN       // Won a tournament
  TOURNAMENT_ENTRY     // Entry fee deducted
  ROYAL_PASS_PURCHASE  // Bought Royal Pass
  TOP_UP               // Razorpay top-up
  TRANSFER_SENT        // Sent B-Coins to another player
  TRANSFER_RECEIVED    // Received B-Coins from another player
  REFERRAL_BONUS       // Referral reward
  STREAK_BONUS         // Streak reward
  SOLO_SUPPORT         // Solo support bonus
  ADMIN_ADJUSTMENT     // Manual adjustment by admin
  SYSTEM               // System-level adjustments
  OTHER                // Catch-all
}

// ─── Models ──────────────────────────────────────────────────

/// Central user — one per Google account across all games.
model CentralUser {
  id        String   @id @default(uuid())
  email     String   @unique          // Google account email
  name      String?                   // Display name from Google
  imageUrl  String?                   // Google profile picture
  
  wallet    CentralWallet?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Single wallet per user — shared balance across all games.
model CentralWallet {
  id       String @id @default(uuid())
  balance  Int    @default(0)
  
  userId   String      @unique
  user     CentralUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transactions CentralTransaction[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Ledger of all B-Coin credits and debits across all games.
model CentralTransaction {
  id            String            @id @default(uuid())
  amount        Int                                         // Always positive
  type          TransactionType                             // CREDIT or DEBIT
  reason        TransactionReason @default(OTHER)
  description   String                                      // Human-readable description
  game          String                                      // "bgmi", "pes", "freefire"
  
  balanceBefore Int                                         // Balance before this transaction
  balanceAfter  Int                                         // Balance after this transaction
  
  metadata      Json?                                       // Extra data (tournament name, player name, etc.)
  
  walletId      String
  wallet        CentralWallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime          @default(now())
  
  @@index([walletId])
  @@index([walletId, createdAt(sort: Desc)])
  @@index([game])
  @@index([reason])
}

// ─── Community (shared across all games) ─────────────────────

/// Community message — feedback/suggestions visible on all game deployments.
model CentralCommunityMessage {
  id          String  @id @default(uuid())
  message     String  @db.VarChar(500)
  category    String  @default("feedback")
  email       String                        // Author's email (cross-game identifier)
  displayName String?                       // Cached display name at time of posting
  imageUrl    String?                       // Cached avatar URL
  game        String                        // Origin game: "bgmi", "pes", "freefire"
  isAnonymous Boolean @default(false)
  isRead      Boolean @default(false)
  adminReply  String?
  upvotes     Int     @default(0)
  downvotes   Int     @default(0)
  isPinned    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes CentralCommunityVote[]

  @@index([email])
  @@index([isRead])
  @@index([createdAt(sort: Desc)])
}

/// Tracks who voted on which community message (one vote per email per message).
model CentralCommunityVote {
  id        String @id @default(uuid())
  messageId String
  email     String
  vote      Int    // 1 = upvote, -1 = downvote

  createdAt DateTime @default(now())

  message CentralCommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, email])
  @@index([messageId])
}

/// Community poll — shared across all game deployments.
model CentralCommunityPoll {
  id          String  @id @default(uuid())
  question    String  @db.VarChar(200)
  email       String                        // Creator's email
  displayName String?                       // Cached display name
  game        String                        // Origin game
  isActive    Boolean @default(true)
  isPinned    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options CentralCommunityPollOption[]
  votes   CentralCommunityPollVote[]

  @@index([email])
  @@index([isActive])
  @@index([createdAt(sort: Desc)])
}

/// An option in a community poll.
model CentralCommunityPollOption {
  id         String  @id @default(uuid())
  pollId     String
  text       String  @db.VarChar(100)
  addedByEmail String
  addedByName  String?
  isApproved Boolean @default(true)

  createdAt DateTime @default(now())

  poll  CentralCommunityPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes CentralCommunityPollVote[]

  @@index([pollId])
}

/// A player's vote on a community poll (one vote per email per poll).
model CentralCommunityPollVote {
  id       String @id @default(uuid())
  pollId   String
  optionId String
  email    String

  createdAt DateTime @default(now())

  poll   CentralCommunityPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option CentralCommunityPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, email])
  @@index([optionId])
}

// ─── Cross-Game Transfers (Settlement Ledger) ────────────────

/// Logs every cross-game currency transfer for manager settlement.
/// "fromGame manager owes toGame manager this amount in real ₹."
model CrossGameTransfer {
  id           String    @id @default(uuid())
  fromGame     String                          // "bgmi", "pes", "mlbb", etc.
  toGame       String                          // Target game
  playerEmail  String                          // Who initiated the transfer
  amount       Int                             // Amount transferred (1:1 across games)
  description  String?                         // e.g. "Self-transfer BGMI → PES"
  isSettled    Boolean   @default(false)        // Has this been settled between managers?
  settledAt    DateTime?
  settledBy    String?                          // Email of admin who marked it settled

  createdAt    DateTime  @default(now())

  @@index([fromGame, toGame])
  @@index([isSettled])
  @@index([playerEmail])
  @@index([createdAt(sort: Desc)])
}

// ─── Settlement Requests (Two-Sided Confirmation) ─────────────

/// When a manager wants to settle, they create a request.
/// The other game's manager must confirm before transfers are marked settled.
model SettlementRequest {
  id              String    @id @default(uuid())
  requestedByGame String                        // Game that initiated ("bgmi")
  otherGame       String                        // Game that must confirm ("pes")
  netAmount       Int                           // Net amount at time of request
  transferCount   Int                           // Number of transfers being settled
  status          String    @default("PENDING") // PENDING | CONFIRMED | REJECTED
  requestedAt     DateTime  @default(now())
  confirmedAt     DateTime?
  rejectedAt      DateTime?

  @@index([requestedByGame, otherGame])
  @@index([status])
}

// ─── Shared Location Data ────────────────────────────────────

/// Indian state or Union Territory — shared across all game deployments.
model CentralLocationState {
  id        String                  @id @default(uuid())
  name      String                  @unique
  districts CentralLocationDistrict[]
  createdAt DateTime                @default(now())
}

/// District within a state — shared across all game deployments.
model CentralLocationDistrict {
  id        String                @id @default(uuid())
  name      String
  stateId   String
  state     CentralLocationState  @relation(fields: [stateId], references: [id], onDelete: Cascade)
  towns     CentralLocationTown[]
  createdAt DateTime              @default(now())

  @@unique([name, stateId])
  @@index([stateId])
}

/// Town/village within a district — shared across all game deployments.
model CentralLocationTown {
  id         String                  @id @default(uuid())
  name       String
  districtId String
  isOfficial Boolean                 @default(false) // true = admin-seeded, false = user-added
  district   CentralLocationDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)
  createdAt  DateTime                @default(now())

  @@unique([name, districtId])
  @@index([districtId])
}
